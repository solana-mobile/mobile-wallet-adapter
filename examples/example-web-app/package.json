{
    "name": "@solana-mobile/example-web-app",
    "author": "Steven Luscher <steven.luscher@solanamobile.com>",
    "repository": "https://github.com/solana-mobile/mobile-wallet-adapter",
    "license": "Apache-2.0",
    "private": true,
    "packageManager": "pnpm@10.30.0",
    "scripts": {
        "build": "pnpm clean && next build",
        "clean": "shx rm -rf .next out",
        "dev": "NODE_OPTIONS='--inspect' next dev --port 3002",
        "format:check": "prettier . --check --cache",
        "format:fix": "prettier . --write",
        "lint": "pnpm lint:check",
        "lint:check": "eslint \"**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}\"",
        "lint:fix": "eslint \"**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}\" --fix",
        "postinstall": "patch-package",
        "preinstall": "(cd ../../js/ && pnpm install && pnpm build)",
        "start": "next start --port 3002",
        "tunnel:start": "ngrok http 3002"
    },
    "dependencies": {
        "@emotion/react": "^11.9.3",
        "@emotion/styled": "^11.9.3",
        "@mui/icons-material": "^5.8.4",
        "@mui/lab": "^5.0.0-alpha.86",
        "@mui/material": "^5.8.4",
        "@solana-mobile/mobile-wallet-adapter-protocol": "link:../../js/packages/mobile-wallet-adapter-protocol",
        "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "link:../../js/packages/mobile-wallet-adapter-protocol-web3js",
        "@solana-mobile/wallet-adapter-mobile": "link:../../js/packages/wallet-adapter-mobile",
        "@solana-mobile/wallet-standard-mobile": "link:../../js/packages/wallet-standard-mobile",
        "@solana/wallet-adapter-base": "^0.9.23",
        "@solana/wallet-adapter-react": "^0.15.35",
        "@solana/wallet-adapter-react-ui": "^0.9.34",
        "@solana/wallet-standard-features": "^1.3.0",
        "@solana/wallet-standard-util": "^1.1.2",
        "@solana/web3.js": "^1.95.3",
        "next": "^15.4.7",
        "notistack": "^2.0.5",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "swr": "^1.3.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.6",
        "@eslint/js": "^10.0.1",
        "@types/node": "20.19.0",
        "@types/react": "^19.2.17",
        "eslint": "^10.7.0",
        "eslint-config-next": "16.2.10",
        "eslint-plugin-simple-import-sort": "^14.0.0",
        "ngrok": "^4.3.1",
        "patch-package": "^8.0.0",
        "postinstall-postinstall": "^2.1.0",
        "prettier": "3.8.4",
        "shx": "^0.4.0",
        "typescript": "~5.6.3"
    },
    "pnpm": {
        "overrides": {
            "ajv": "^6.14.0",
            "postcss": "^8.4.31"
        }
    }
}
